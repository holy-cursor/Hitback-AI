{
  "name": "hitback-extension",
  "displayName": "HitBack — AI Wait State Ads",
  "description": "Shows sponsored ads while Cursor's agent is working",
  "version": "0.5.0",
  "publisher": "hitback",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hitback.adClick",
        "title": "HitBack: Open Ad Link"
      },
      {
        "command": "hitback.testAd",
        "title": "HitBack: Test Ad (Debug)"
      },
      {
        "command": "hitback.login",
        "title": "HitBack: Login"
      },
      {
        "command": "hitback.logout",
        "title": "HitBack: Logout"
      }
    ],
    "configuration": {
      "title": "HitBack",
      "properties": {
        "hitback.backendUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "URL of the HitBack ad server backend"
        },
        "hitback.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable HitBack ads"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
