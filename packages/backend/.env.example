# HitBack Backend — Environment Variables

# Server
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Stripe (Phase 7)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Session (Phase 6)
SESSION_SECRET=change-me-to-a-random-string

# Serve tokens (impression/click attestation — falls back to SESSION_SECRET)
IMPRESSION_TOKEN_SECRET=change-me-to-a-different-random-string

# Frontend URL (OAuth redirects, Stripe return URLs)
# Vercel frontend: https://hitback.xyz
# Also whitelist https://www.hitback.xyz in Supabase Redirect URLs
# Fly portal (temporary): https://api.hitback.xyz/portal
FRONTEND_URL=https://hitback.xyz

# Google OAuth (configure in Supabase Dashboard, not here):
# Google Cloud redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# Supabase → Auth → Providers → Google → Client ID + Client Secret from Google Cloud

# Admin API (protects /api/admin/* routes)
ADMIN_API_KEY=change-me-to-a-random-string
