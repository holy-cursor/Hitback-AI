# HitBack Backend — Environment Variables

# Server
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Stripe (Phase 7)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Session (Phase 6)
SESSION_SECRET=change-me-to-a-random-string

# Frontend URL (OAuth redirects, Stripe return URLs)
# Fly (portal on same app): https://your-app.fly.dev/portal
# Custom domain: https://yourdomain.com/portal or https://api.yourdomain.com/portal
FRONTEND_URL=http://localhost:3001/portal

# Admin API (protects /api/admin/* routes)
ADMIN_API_KEY=change-me-to-a-random-string
